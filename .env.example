# Copy to .env and fill in from the Supabase dashboard.

# Settings -> API -> Project URL.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Settings -> API -> Project API keys -> service_role secret. Click "reveal" to
# see it. Server only — this key bypasses RLS, never send it to the frontend.
SUPABASE_SECRET_KEY=

# Settings -> Database -> Connection string -> URI tab. NOT the same page as
# the keys above. Supabase shows this with a literal "[YOUR-PASSWORD]"
# placeholder — replace it with your actual database password (set at project
# creation; use "Reset database password" on that same page if you don't have
# it). Prefer the "Transaction pooler" connection (port 6543) over the direct
# connection (port 5432) — this server opens short-lived pooled connections,
# not a persistent one. Example shape:
# postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Authentication -> Users -> the one admin user you created -> copy its UUID
# (shown in the users table / user detail page).
ADMIN_USER_ID=

PORT=8080

# Deployed frontend origin in prod (e.g. https://example.com, no trailing
# slash); leave empty in dev — Vite proxies /api to this server directly.
ALLOWED_ORIGIN=
